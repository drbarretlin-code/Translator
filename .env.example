# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ==========================================
# 專案所需 API 密鑰說明 (API Keys Requirements)
# ==========================================
# 1. Gemini API Key (必要)
#    - 用途：負責將語音辨識後的文字進行高品質的多國語言翻譯。
#    - 注意：在 AI Studio 環境中，此金鑰會自動注入，無需手動修改此檔案。
#
# 2. Web Speech API (無需金鑰)
#    - 用途：前端即時語音轉文字 (STT)。
#    - 說明：這是一個瀏覽器內建的 API，完全免費且無需申請任何金鑰。支援 Chrome、Edge 等現代瀏覽器。
# ==========================================
